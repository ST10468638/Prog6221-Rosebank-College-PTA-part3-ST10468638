<Window x:Class="CyberSecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Grid>

        <!-- MAIN BACKGROUND (WhatsApp style dark theme) -->
        <Grid.Background>
            <ImageBrush ImageSource="https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5"
                        Stretch="UniformToFill"
                        Opacity="0.25"/>
        </Grid.Background>

        <!-- DARK OVERLAY -->
        <Rectangle Fill="#AA000000"/>

        <!-- MAIN CONTAINER -->
        <Border Background="#CC111111"
                CornerRadius="20"
                Margin="20"
                Padding="20">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Grid.Row="0"
                            Margin="0,0,0,20">

                    <TextBlock Text="🔐 CYBERSECURITY AWARENESS BOT 🔐"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="Lime"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Protect Yourself • Stay Safe Online"
                               FontSize="14"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Opacity="0.8"
                               Margin="0,5,0,15"/>

                </StackPanel>

                <!-- CHAT AREA (WhatsApp style panel) -->
                <Border Grid.Row="1"
                        CornerRadius="20"
                        Padding="15"
                        Background="#ffff"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1">

                    <ScrollViewer x:Name="ChatScrollViewer"
                                  VerticalScrollBarVisibility="Auto">

                        <StackPanel x:Name="ChatPanel"/>

                    </ScrollViewer>

                </Border>

                <!-- INPUT AREA -->
                <Grid Grid.Row="2"
                      Margin="0,15,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <!-- INPUT BOX -->
                    <Border Grid.Column="0"
                            Background="#222"
                            CornerRadius="25"
                            BorderBrush="Lime"
                            BorderThickness="2"
                            Margin="0,0,10,0">

                        <TextBox x:Name="UserInput"
                                 Background="Transparent"
                                 Foreground="White"
                                 FontSize="15"
                                 BorderThickness="0"
                                 Padding="12"
                                 CaretBrush="White"
                                 KeyDown="UserInput_KeyDown"/>
                    </Border>

                    <!-- SEND BUTTON -->
                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Content="Send"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="Lime"
                            Foreground="Black"
                            Cursor="Hand"
                            Height="45"
                            Click="SendButton_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="25">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>